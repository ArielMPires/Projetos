@page "/NC83"

@using NexuSys.DTOs.Purchase
@using NexuSys.Interfaces
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject IPurchase _service

<PageTitle>Compras</PageTitle>

<div class="container py-4 bg-white">

    <!-- CABEÇALHO -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold mb-4">Compras</h3>

        <NavLink class="btn btn-success" href="/NC84">
            <i class="bi bi-plus-circle"></i> Nova Compra
        </NavLink>
    </div>

    <!-- PESQUISA -->
    <div class="input-group mb-3">
        <span class="input-group-text">
            <i class="bi bi-search"></i>
        </span>
        <input type="text"
               class="form-control"
               placeholder="Pesquisar por NF ou Fornecedor..."
               @bind="Filtro"
               @bind:event="oninput" />
    </div>

    <!-- TABELA -->
    <div class="card shadow-sm p-3">
        <table class="table table-striped align-middle">
            <thead class="table-light">
                <tr>
                    <th>ID</th>
                    <th>NF</th>
                    <th>Fornecedor</th>
                    <th>Data</th>
                    <th>Valor Total</th>
                    <th class="text-end pe-4">Ações</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var compra in Compras)
                {
                    <tr>
                        <td>@compra.ID</td>
                        <td>@compra.NF</td>
                        <td>@compra.Supplier</td>
                        <td>@compra.Date.ToShortDateString()</td>
                        <td>@compra.Value_total.ToString("C")</td>

                        <td>
                            <div class="text-end pe-1">
                         

                                <button class="btn btn-sm btn-outline-danger"
                                        @onclick="() => Excluir(compra.ID)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }

                @if (!Compras.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">
                            Nenhuma compra encontrada
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {





    string Filtro = "";

    private List<PurchaseDTO> Compras = new();

    IEnumerable<PurchaseDTO> ProdutosFiltrados =>
        Compras.Where(d =>
            string.IsNullOrWhiteSpace(Filtro) ||
            d.ID.ToString().Contains(Filtro, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        Compras = await _service.PurchaseList();
    }

    private string RemoverAcentos(string texto)
    {
        return new string(texto
            .Normalize(System.Text.NormalizationForm.FormD)
            .Where(ch => System.Globalization.CharUnicodeInfo.GetUnicodeCategory(ch) != System.Globalization.UnicodeCategory.NonSpacingMark)
            .ToArray());
    }

    private void Pesquisar()
    {
        StateHasChanged();
    }

    private async void Excluir(int id)
    {
        bool confirmar = await JS.InvokeAsync<bool>("confirm", "Deseja excluir este Produto?");
        if (confirmar)
        {
            await _service.DeletePurchase(id);
            Compras = await _service.PurchaseList();
            StateHasChanged();
        }
    }



   
}