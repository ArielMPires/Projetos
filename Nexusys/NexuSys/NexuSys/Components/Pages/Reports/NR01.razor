@page "/NR01"
@rendermode InteractiveServer
@inject NavigationManager Navigation

<div class="container py-4 bg-white">
    <h2 class="fw-bold mb-4">Relatórios</h2>

    <!-- Botões de Exportação -->
    <div class="mb-4 d-flex justify-content-end">
        <button class="btn btn-success me-2 d-flex j" @onclick="ExportarCsv">Exportar CSV</button>
        <button class="btn btn-danger" @onclick="ExportarPdf">Exportar PDF</button>
    </div>

    <!-- Filtros -->
    <div class="card shadow-sm mb-4 p-3">
        <div class="row g-3">
            <div class="col-md-2">
                <label class="form-label">Data Início</label>
                <InputDate class="form-control" @bind-Value="filtro.DataInicio" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Data Fim</label>
                <InputDate class="form-control" @bind-Value="filtro.DataFim" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Tipo Equipamento</label>
                <InputSelect class="form-control" @bind-Value="filtro.TipoEquipamento">
                    <option value="Todos">Todos</option>
                    <option value="Inversores">Inversores</option>
                    <option value="Soft-Starters">Soft-Starters</option>
                </InputSelect>
            </div>
            <div class="col-md-2">
                <label class="form-label">Status</label>
                <InputSelect class="form-control" @bind-Value="filtro.Status">
                    <option value="Todos">Todos</option>
                    <option value="Aberto">Aberto</option>
                    <option value="Em Andamento">Em Andamento</option>
                    <option value="Aguardando Peças">Aguardando Peças</option>
                    <option value="Aguardando Aprovação">Aguardando Aprovação</option>
                    <option value="Concluído">Concluído</option>
                </InputSelect>
            </div>
            <div class="col-md-2">
                <label class="form-label">Técnico</label>
                <InputSelect class="form-control" @bind-Value="filtro.Tecnico">
                    <option value="Todos">Todos</option>
                    <option value="João">João</option>
                    <option value="Maria">Maria</option>
                    <option value="Carlos">Carlos</option>
                </InputSelect>
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button class="btn btn-primary w-100" @onclick="AplicarFiltros">Aplicar</button>
            </div>
        </div>
    </div>

    <!-- Métricas -->
    <div class="row text-center">
        <div class="col-md-3">
            <div class="card shadow-sm p-3">
                <h6>Total de OS</h6>
                <h4>@resultado.TotalOS</h4>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm p-3">
                <h6>Concluídas</h6>
                <h4>@resultado.Concluidas</h4>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm p-3">
                <h6>Total Orçamentos</h6>
                <h4>R$ @resultado.TotalOrcamentos</h4>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm p-3">
                <h6>Total Faturado</h6>
                <h4>R$ @resultado.TotalFaturado</h4>
            </div>
        </div>
    </div>

    <!-- Abas -->
    <ul class="nav nav-tabs mb-3" id="relatorioTabs">
        <li class="nav-item">
            <a class="nav-link active" data-bs-toggle="tab" href="NR01">Visão Geral</a>
        </li>
        <li class="nav-item">
            <a class="nav-link" data-bs-toggle="tab" href="NR02">Por Técnico</a>
        </li>
        <li class="nav-item">
            <a class="nav-link" data-bs-toggle="tab" href="NR03">Detalhado</a>
        </li>
    </ul>

    <div class="tab-content">
        <!-- Visão Geral -->
        <div class="tab-pane fade show active" id="geral">
            <div class="card shadow-sm mb-4 p-3">
                <h5 class="fw-bold">Distribuição por Status</h5>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item">Aberto: 0</li>
                    <li class="list-group-item">Em Andamento: 0</li>
                    <li class="list-group-item">Aguardando Peças: 0</li>
                    <li class="list-group-item">Aguardando Aprovação: 0</li>
                    <li class="list-group-item">Concluído: 0</li>
                </ul>
            </div>

            <div class="card shadow-sm mb-4 p-3">
                <h5 class="fw-bold">Distribuição por Tipo de Equipamento</h5>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item">Inversores: 0 OS</li>
                    <li class="list-group-item">Soft-Starters: 0 OS</li>
                </ul>
            </div>
        </div>

        <!-- Por Técnico -->
        <div class="tab-pane fade" id="tecnico">
            <div class="card shadow-sm p-3">
                <h5 class="fw-bold">Relatório por Técnico</h5>
                <p>Aqui você pode listar os técnicos e suas OS.</p>
            </div>
        </div>

        <!-- Detalhado -->
        <div class="tab-pane fade" id="detalhado">
            <div class="card shadow-sm p-3">
                <h5 class="fw-bold">Relatório Detalhado</h5>
                <p>Aqui você pode mostrar uma tabela detalhada com todas as OS.</p>
            </div>
        </div>
    </div>
</div>

@code {

    private Filtro filtro = new();
    private Resultado resultado = new Resultado();

    public class Filtro
    {
        public DateTime DataInicio { get; set; } = new DateTime(2024, 1, 1);
        public DateTime DataFim { get; set; } = new DateTime(2024, 12, 31);
        public string TipoEquipamento { get; set; } = "Todos";
        public string Status { get; set; } = "Todos";
        public string Tecnico { get; set; } = "Todos";
    }

    public class Resultado
    {
        public int TotalOS { get; set; } = 0;
        public int Concluidas { get; set; } = 0;
        public decimal TotalOrcamentos { get; set; } = 0;
        public decimal TotalFaturado { get; set; } = 0;
    }

    private void AplicarFiltros()
    {
        // Aqui você faria a consulta no banco ou API
        resultado.TotalOS = 10;
        resultado.Concluidas = 7;
        resultado.TotalOrcamentos = 15000.50m;
        resultado.TotalFaturado = 12000.00m;
    }

    private void ExportarCsv()
    {
        // Lógica para exportar CSV
    }

    private void ExportarPdf()
    {
        // Lógica para exportar PDF
    }
}