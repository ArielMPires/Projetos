@page "/NA41"
@using NexuSys.DTOs.Repair_Activities
@using NexuSys.Interfaces
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject IBudget _service
@inject IJSRuntime JS

<PageTitle>Atividades de Reparo </PageTitle>

<div class="container py-4 bg-white">

    <div class="d-flex justify-content-between align-items-start mb-4">

        <div>
            <h3 class="fw-bold mb-4">Atividades de Reparo</h3>
            <small class="text-muted">Gerencie as atividades de reparo</small>
        </div>

        <button class="btn btn-success" @onclick="NovaAtividade">
            <i class="bi bi-plus-circle"></i> Nova Atividade
        </button>

    </div>

    <div class="input-group mb-3">
        <span class="input-group-text">
            <i class="bi bi-search"></i>
        </span>

        <input type="text"
               class="form-control"
               placeholder="Pesquisar atividade..."
               @bind="Filtro"
               @bind:event="oninput" />
    </div>

    <div class="card shadow-sm p-3">

        <table class="table table-hover align-middle">

            <thead class="table-light">
                <tr>
                    <th>ID</th>
                    <th>Nome</th>
                    <th class="text-end pe-4">Ações</th>
                </tr>
            </thead>

            <tbody>

                @if (ActivitiesFiltradas.Any())
                {
                    @foreach (var item in ActivitiesFiltradas)
                    {
                        <tr>

                            <td>@item.ID</td>

                            <td>@item.Name</td>

                            <td class="text-end pe-3">

                                <button class="btn btn-sm btn-outline-primary me-1"
                                        @onclick="() => Editar(item.ID)">
                                    <i class="bi bi-pencil"></i>
                                </button>

                                <button class="btn btn-sm btn-outline-danger"
                                        @onclick="() => Excluir(item.ID)">
                                    <i class="bi bi-trash"></i>
                                </button>

                            </td>

                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="3" class="text-center text-muted py-4">
                            Nenhuma atividade encontrada
                        </td>
                    </tr>
                }

            </tbody>

        </table>

    </div>

    <div class="mt-3 text-muted">
        Quantidade de atividades: @ActivitiesFiltradas.Count()
    </div>

</div>

@code {

    private string Filtro = "";

    private List<Repair_ActivitiesDTO> activities = new();

    IEnumerable<Repair_ActivitiesDTO> ActivitiesFiltradas =>
        activities.Where(a =>
            string.IsNullOrWhiteSpace(Filtro) ||
            a.Name.Contains(Filtro, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        activities = await _service.Repair_ActivitiesList();
    }

    void NovaAtividade()
    {
        Navigation.NavigateTo("/NN07");
    }

    void Editar(int id)
    {
        Navigation.NavigateTo($"/NE25/{id}");
    }

    async Task Excluir(int id)
    {
        bool confirmar = await JS.InvokeAsync<bool>(
            "confirm",
            "Deseja excluir esta atividade?"
        );

        if (confirmar)
        {
            await _service.DeleteRepair_Activities(id);
            activities = await _service.Repair_ActivitiesList();
        }
    }

}