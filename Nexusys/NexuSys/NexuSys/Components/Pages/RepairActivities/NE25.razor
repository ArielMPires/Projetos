@page "/NE25/{id:int}"
@using NexuSys.DTOs.Repair_Activities
@using NexuSys.Interfaces
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject IBudget _service
@inject IJSRuntime JS

<PageTitle>Editar Atividade</PageTitle>

@if (IsLoading)
{
    <div class="loading-overlay">
        <div class="spinner-border text-light" role="status"></div>
        <p class="mt-3 text-light fw-bold">Salvando alterações...</p>
    </div>
}

<EditForm Model="Model" OnValidSubmit="Salvar">

    <div class="container-fluid p-4">

        <h3 class="fw-bold mb-4">Editar Atividade</h3>
        <p class="text-muted">
            Atualize o nome da atividade de reparo
        </p>

        <div class="card">
            <div class="card-body">

                <fieldset disabled="@IsLoading">

                    <div class="mb-3">

                        <label class="form-label">Nome</label>

                        <InputText class="form-control"
                                   @bind-Value="Model.Name"
                                   placeholder="Digite o nome da atividade" />

                    </div>

                    <div class="d-flex justify-content-end">

                        <button type="button"
                                class="btn btn-secondary me-2"
                                @onclick="Voltar"
                                disabled="@IsLoading">
                            Cancelar
                        </button>

                        <button class="btn btn-primary"
                                type="submit"
                                disabled="@IsLoading">

                            @if (IsLoading)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                                <span>Atualizando...</span>
                            }
                            else
                            {
                                <span>Salvar Alterações</span>
                            }

                        </button>

                    </div>

                </fieldset>

            </div>
        </div>

    </div>

</EditForm>

@code {

    [Parameter]
    public int id { get; set; }

    private EditRepair_ActivitiesDTO Model = new();

    private bool IsLoading = false;
    protected override async Task OnInitializedAsync()
    {
        var activity = await _service.Repair_ActivitiesByID(id);

        if (activity != null)
        {
            Model.ID = activity.ID;
            Model.Name = activity.Name;
            Model.History = activity.History; 
        }
    }

    async Task Salvar()
    {
        if (IsLoading)
            return;

        if (string.IsNullOrWhiteSpace(Model.Name))
        {
            await JS.InvokeVoidAsync("alert", "Informe o nome da atividade.");
            return;
        }

        IsLoading = true;
        StateHasChanged();

        try
        {
            var response = await _service.UpdateRepair_Activities(Model);

            if (response.Result)
            {
                await JS.InvokeVoidAsync("alert", response.Message);

                Navigation.NavigateTo("/NA41");
            }
            else
            {
                await JS.InvokeVoidAsync("alert", response.Error);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex);
            await JS.InvokeVoidAsync("alert", "Erro ao atualizar atividade.");
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    void Voltar()
    {
        if (!IsLoading)
            Navigation.NavigateTo("/NA41");
    }

}