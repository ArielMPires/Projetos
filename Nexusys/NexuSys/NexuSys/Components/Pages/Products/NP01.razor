@page "/NP01"
@using NexuSys.DTOs.Products
@using NexuSys.Helper
@using NexuSys.Interfaces
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject IProducts _service
@inject IUserContext UserContext

<div class="container py-4 bg-white">

    <div class="d-flex justify-content-between align-items-center mb-4">

    <h3 class="fw-bold mb-4">Estoque dos Produtos</h3>
        <NavLink class="btn btn-success" href="/NP02">
            <i class="bi bi-plus-circle"></i> Novo Produto
        </NavLink>
    </div>

    <!-- Área de Pesquisa -->
    <div class="input-group mb-3">
        <span class="input-group-text"><i class="bi bi-search"></i></span>
        <input type="text" class="form-control" placeholder="Pesquisar produto..." />
    </div>

    <!-- Mensagem de exclusão com opção de desfazer -->

    <!-- Tabela de Produtos -->
    <div class="card shadow-sm p-3">
        <table class="table table-striped align-middle">
            <thead class="table-light">
                <tr>
                    <th>Produto</th>
                    <th>Descrição</th>
                    <th>NCM</th>               
                    <th>Preço</th>
                    <th>Quantidade</th>
                    <th class="text-end pe-4">Ações</th>

                </tr>
            </thead>
            <tbody>
                @foreach (var produto in ProdutosFiltrados)
                {
                    <tr>
                        <td>@produto.ID</td>
                        <td>@produto.SAP_Description</td>
                        <td>@produto.NCM</td>
                        <td>R$ @produto.Gross_Price</td>                       
                        <td>@produto.Stock</td>                       
                        <td>
                            <div class="text-end pe-1">
                                <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => EditarProduto(produto.ID)">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => Excluir(produto.ID)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="mt-3 text-muted">
        Quantidade de serviços: @ProdutosFiltrados.Count()
    </div>
</div>

@code {





    string Filtro = "";

    private List<ProductsDTO> Produtos = new();

    IEnumerable<ProductsDTO> ProdutosFiltrados =>
        Produtos.Where(d =>
            string.IsNullOrWhiteSpace(Filtro) ||
            d.ID.ToString().Contains(Filtro, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        Produtos = await _service.ProductsList();
    }

    private string RemoverAcentos(string texto)
    {
        return new string(texto
            .Normalize(System.Text.NormalizationForm.FormD)
            .Where(ch => System.Globalization.CharUnicodeInfo.GetUnicodeCategory(ch) != System.Globalization.UnicodeCategory.NonSpacingMark)
            .ToArray());
    }

    private void Pesquisar()
    {
        StateHasChanged();
    }

    private async void Excluir(int id)
    {
        bool confirmar = await JS.InvokeAsync<bool>("confirm", "Deseja excluir este Produto?");
        if (confirmar)
        {
            await _service.DeleteProducts(id);
            Produtos = await _service.ProductsList();
            StateHasChanged();
        }
    }



    void EditarProduto(int id) => Navigation.NavigateTo($"/NP03/{id}");
}