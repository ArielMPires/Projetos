@page "/NP02"
@using NexuSys.DTOs.Products
@using NexuSys.Helper
@using NexuSys.Interfaces
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject IProducts _service
@inject IUserContext UserContext

<EditForm Model="Model" OnInvalidSubmit="Finalizar">

<div class="container py-4 bg-white">
    <h3 class="fw-bold mb-4">Cadastrar Novo Produto</h3>

    <div class="row">
        <!-- Menu lateral de etapas -->
        <div class="col-md-3">
            <ul class="list-group">
                <li class="list-group-item @(etapaAtual == 1 ? "active" : "")" @onclick="() => etapaAtual = 1">Dados Básicos</li>
                <li class="list-group-item @(etapaAtual == 2 ? "active" : "")" @onclick="() => etapaAtual = 2">Dados de Medidas</li>
            </ul>
        </div>

        <!-- Conteúdo principal -->
        <div class="col-md-9">
            @if (etapaAtual == 1)
            {
                <div class="card shadow-sm p-3">
                    <h5 class="fw-bold">Dados Básicos</h5>

                    <div class="mb-3">
                        <label class="form-label">ID do Produto</label>
                        <InputNumber class="form-control" @bind-Value="Model.ID" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Familia</label>
                        <InputText class="form-control" @bind-Value="Model.Family" />
                    </div>

                        <div class="mb-3">
                            <label class="form-label">Descrição</label>
                            <InputText class="form-control" @bind-Value="Model.SAP_Description" />
                        </div>

                    <!-- Cada opção virou InputText -->
                    <div class="mb-3">
                        <label class="form-label">Embalagem</label>
                        <InputText class="form-control" @bind-Value="Model.Packaging" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Preço Bruto</label>
                        <InputNumber  class="form-control" @bind-Value="Model.Gross_Price" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Ipi</label>
                        <InputText class="form-control" @bind-Value="Model.IPI" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Código de Barra</label>
                        <InputText class="form-control" @bind-Value="Model.Barcode" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">NCM</label>
                        <InputNumber class="form-control" @bind-Value="Model.NCM" />
                    </div>
                   
                    <div class="mb-3">
                        <label class="form-label">Hierárquia</label>
                        <InputText class="form-control" @bind-Value="Model.Hierarchy" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">CNPJ do Fornecedor</label>
                        <InputText class="form-control" @bind-Value="Model.Billing_CNPJ" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Origem CST</label>
                        <InputText class="form-control" @bind-Value="Model.Origin_CST" />
                    </div>
                </div>
            }
            else if (etapaAtual == 2)
            {
                    <div class="mb-3">
                        <label class="form-label">Comprimento</label>
                        <InputNumber class="form-control" @bind-Value="Model.Length" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Largura</label>
                        <InputNumber class="form-control" @bind-Value="Model.Width" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Altura</label>
                        <InputNumber class="form-control" @bind-Value="Model.Height" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Unidade de Peso</label>
                        <InputText class="form-control" @bind-Value="Model.Weight_Unit" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Peso Líquido</label>
                        <InputNumber class="form-control" @bind-Value="Model.Net_Weight" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Peso Bruto</label>
                        <InputNumber class="form-control" @bind-Value="Model.Gross_Weight" />
                    </div>
            }

            <!-- Botões de navegação -->
            <div class="mt-3 d-flex justify-content-between">
                <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
                <div>
                        <button class="btn btn-outline-secondary me-2" @onclick="Anterior" disabled="@(etapaAtual == 2)">Voltar</button>
                    <button class="btn btn-success" type="submit" @onclick="Proximo">@((etapaAtual == 2) ? "Cadastrar Produto" : "Avançar")</button>
                </div>
            </div>
        </div>
    </div>
 </div>
</EditForm>

@code {

    private int etapaAtual = 1;

    private void Proximo()
    {
        if (etapaAtual < 2) etapaAtual++;
        else Finalizar();
    }

    private void Anterior()
    {
        if (etapaAtual > 2) etapaAtual--;
    }

    private void Cancelar()
    {

        Navigation.NavigateTo("/NP01");
    }

    private NewProductsDTO Model = new();

    async void Finalizar()
    {
        Model.CreateBy = UserContext.UserId;
        Model.DateCreate = DateTime.Now;

        try
        {
            var producto = await _service.NewProducts(Model);

            if (producto.Result)
            {
                await JS.InvokeVoidAsync("alert", producto.Message);
                Navigation.NavigateTo("/NP01");
            }
            else
            {
                await JS.InvokeVoidAsync("alert", producto.Error);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.InnerException?.Message);
        }
    }
}
