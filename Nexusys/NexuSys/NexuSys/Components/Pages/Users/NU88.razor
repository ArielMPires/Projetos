@page "/NU88"
@using NexuSys.DTOs.Users
@using NexuSys.Interfaces
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject IUsers _service
@inject IJSRuntime JS

<PageTitle>Usuários</PageTitle>

<div class="container py-4 bg-white">

    <div class="d-flex justify-content-between align-items-start mb-3">

        <div>
            <h3 class="fw-bold">Usuários</h3>
            <small class="text-muted">Gerencie o cadastro de usuários</small>
        </div>

        <button class="btn btn-success" @onclick="NovoUsuario">
            <i class="bi bi-plus-circle"></i> Adicionar Usuário
        </button>
    </div>


    <!-- Área de Pesquisa -->
    <div class="input-group mb-3">
        <span class="input-group-text">
            <i class="bi bi-search"></i>
        </span>
        <input type="text"
               class="form-control"
               placeholder="Pesquisar Usuário..."
               @bind="Filtro"
               @bind:event="oninput" />

    </div>

    <div class="card shadow-sm p-3">
            <table class="table table-hover align-middle mb-0 ">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Nome do Usuário</th>
                        <th>Email</th>
                        <th>Função</th>
                        <th class="text-end pe-5">Ações</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var u in UsuariosFiltrados)
                    {
                        <tr>
                            <td>@u.ID</td>
                            <td>@u.Name</td>
                            <td>@u.Email</td>
                            <td>@u.Role</td>

                            <td class="text-end">

                                <!-- RESETAR SENHA -->
                                <button class="btn btn-sm btn-outline-primary me-1 ps-1 pe-1"
                                        title="Resetar Senha">
                                    <i class="bi bi-arrow-repeat"></i>
                                    Resetar senha
                                </button>

                                <!-- EDITAR -->
                                <button class="btn btn-sm btn-outline-primary me-1"
                                        title="Editar"
                                        @onclick="() => Editar(u.ID)">
                                    <i class="bi bi-pencil"></i>
                                </button>

                                <!-- EXCLUIR -->
                                <button class="btn btn-sm btn-outline-danger"
                                        title="Excluir"
                                        @onclick="() => ConfirmarExclusao(u.ID)">
                                    <i class="bi bi-trash"></i>
                                </button>

                            </td>
                        </tr>
                    }

                    @if (!UsuariosFiltrados.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">
                                Nenhum usuário encontrado
                            </td>
                        </tr>
                    }

                </tbody>
            </table>

     
    </div>

    <div class="mt-3 text-muted">
        Quantidade de Usuários: @UsuariosFiltrados.Count()
    </div>

</div>

@code {

    string Filtro = "";

    private List<UserDTO> Usuarios = new();

    IEnumerable<UserDTO> UsuariosFiltrados =>
        Usuarios.Where(u =>
            string.IsNullOrWhiteSpace(Filtro) ||
            u.Name.Contains(Filtro, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        Usuarios = await _service.UserList();
    }

    void NovoUsuario()
    {
        Navigation.NavigateTo("/NC47");
    }

    void Editar(int id)
    {
        Navigation.NavigateTo($"/NE98/{id}");
    }

    async Task ConfirmarExclusao(int id)
    {
        bool ok = await JS.InvokeAsync<bool>(
            "confirm", "Deseja excluir este usuário?"
        );

        if (ok)
        {
            var result = await _service.DeleteUser(id);

            if (result.Result)
            {
                Usuarios.RemoveAll(u => u.ID == id);
            }
            else
            {
                await JS.InvokeVoidAsync("alert", result.Message);
            }
        }
    }
}