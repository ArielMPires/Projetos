@page "/NC47"
@using NexuSys.DTOs.Departament
@using NexuSys.DTOs.Role
@using NexuSys.DTOs.Users
@using NexuSys.DTOs.Role
@using NexuSys.Helper
@using NexuSys.Interfaces
@rendermode InteractiveServer

@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject IUsers _service
@inject IUsers _roleService
@inject IUserContext userContext

<PageTitle>Novo Usuário</PageTitle>

@if (IsLoading)
{
    <div class="loading-overlay">
        <div class="spinner-border text-light" role="status"></div>
        <p class="mt-3 text-light fw-bold">Salvando usuário...</p>
    </div>
}

<div class="container-fluid p-4">

    <h3 class="fw-bold">Novo Usuário</h3>
    <p class="text-muted">Preencha os dados abaixo para cadastrar um novo Usuário</p>

    <div class="card shadow-sm p-4 mt-3">
        <div class="card-body">

            <EditForm Model="Model" OnValidSubmit="Salvar">

                <fieldset disabled="@IsLoading">

                    <div class="mb-3">
                        <label class="form-label">Usuário <span class="text-danger">*</span></label>
                        <InputText class="form-control"
                                   @bind-Value="Model.Name"
                                   placeholder="Digite aqui o nome do usuário" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Senha <span class="text-danger">*</span></label>
                        <InputText type="password"
                                   class="form-control"
                                   @bind-Value="Model.Password"
                                   placeholder="Digite a senha do usuário" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Email <span class="text-danger">*</span></label>
                        <InputText class="form-control"
                                   @bind-Value="Model.Email"
                                   placeholder="Digite aqui o email" />
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Departamento <span class="text-danger">*</span></label>
                            <InputSelect class="form-select"
                                         @bind-Value="Model.Department">
                                <option value="">Selecione o Departamento</option>

                                @foreach (var item in departments)
                                {
                                    <option value="@item.ID">@item.Name</option>
                                }
                            </InputSelect>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Função <span class="text-danger">*</span></label>
                            <InputSelect class="form-select"
                                         @bind-Value="Model.Role">
                                <option value="">Selecione a Função</option>

                                @foreach (var item in roles)
                                {
                                    <option value="@item.ID">@item.Name</option>
                                }
                            </InputSelect>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end mt-4">
                        <button type="button"
                                class="btn btn-secondary me-2"
                                @onclick="Voltar"
                                disabled="@IsLoading">
                            Cancelar
                        </button>

                        <button type="submit"
                                class="btn btn-success"
                                disabled="@IsLoading">
                            @if (IsLoading)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                                
                            }
                            else
                            {
                                <span>Cadastrar Usuário</span>
                            }
                        </button>
                    </div>

                </fieldset>

            </EditForm>

        </div>
    </div>

</div>

@code {

    private NewUserDTO Model = new();
    private List<DepartamentDTO> departments = new();
    private List<RoleDTO> roles = new();
    private bool IsLoading = false;

    protected override async Task OnInitializedAsync()
    {
        departments = await _service.DepartamentList();
        roles = await _service.RoleList();
    }

    async Task Salvar()
    {
        if (IsLoading)
            return;

        IsLoading = true;
        StateHasChanged();

        Model.CreateBy = userContext.UserId;
        Model.DateCreate = DateTime.Now;

        try
        {
            var response = await _service.NewUser(Model);

            if (response.Result)
            {
                await JS.InvokeVoidAsync("alert", response.Message);
                Navigation.NavigateTo("/NU88");
            }
            else
            {
                await JS.InvokeVoidAsync("alert", response.Error);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex);
            await JS.InvokeVoidAsync("alert", "Erro ao cadastrar usuário.");
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    void Voltar()
    {
        if (!IsLoading)
            Navigation.NavigateTo("/NU88");
    }
}