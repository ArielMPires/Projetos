@page "/SE64/{Id:int}"
@using NexuSys.DTOs.SItuation
@using NexuSys.Helper
@using NexuSys.Interfaces
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject IService _service
@inject IUserContext UserContext
@inject IJSRuntime JS

<PageTitle>Editar Situação</PageTitle>

@if (IsLoading)
{
    <div class="loading-overlay">
        <div class="spinner-border text-light"></div>
        <p class="mt-3 text-light">Salvando alterações...</p>
    </div>
}

<div class="container py-4 bg-white">

    <h3 class="fw-bold mb-4">Editar Situação</h3>

   
        <div class="card shadow-sm p-3">

            <fieldset disabled="@IsLoading">

                <div class="mb-3">
                    <label class="form-label">Nome da Situação</label>
                    <input class="form-control" @bind="Model.Name" />
                </div>

                <div class="d-flex justify-content-end">
                    <button class="btn btn-secondary me-2"
                            @onclick="Voltar"
                            disabled="@IsLoading">
                        Cancelar
                    </button>

                    <button class="btn btn-success"
                            @onclick="Salvar"
                            disabled="@IsLoading">
                        @(IsLoading ? "Salvando..." : "Salvar Alterações")
                    </button>
                </div>

            </fieldset>

        </div>
</div>



@code {
    [Parameter] public int Id { get; set; }

    private BySituationDTO Model = new();
    private bool IsLoading = false;

    protected override async Task OnInitializedAsync()
    {
        var situations = await _service.SituationByID(Id);
        Model.Name = situations.Name;
        Model.ID = situations.ID;
        Model.History = situations.History;
        Model.CreateBy = situations.CreateBy;
        Model.DateCreate = situations.DateCreate;
    }

    async Task Salvar()
    {
        if (IsLoading) return;
        IsLoading = true;

        Model.CreateBy = UserContext.UserId;
        Model.DateCreate = DateTime.Now;
        Model.ChangedBy = UserContext.UserId;
        Model.DateChanged = DateTime.Now;

        try
        {
            var response = await _service.UpdateSituation(Model);
            await JS.InvokeVoidAsync("alert", response.Result ? response.Message : response.Error);

            if (response.Result)
                Navigation.NavigateTo("/NS42");
        }
        finally
        {
            IsLoading = false;
        }
    }

    void Voltar()
    {
        if (!IsLoading)
            Navigation.NavigateTo("/NS42");
    }
}