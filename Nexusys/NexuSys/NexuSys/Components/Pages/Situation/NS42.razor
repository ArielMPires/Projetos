@page "/NS42"
@using NexuSys.DTOs.SItuation
@using NexuSys.Interfaces
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject IService _service
@inject IJSRuntime JS

<PageTitle>Situações</PageTitle>

<div class="container py-4 bg-white">

    <div class="d-flex justify-content-between align-items-start mb-4">

        <div>
            <h3 class="fw-bold mb-4 ">Situações</h3>
            <small class="text-muted">Gerencie o cadastro de situações</small>
        </div>
        
        <button class="btn btn-success" @onclick="NovaSituacao">
            <i class="bi bi-plus-circle"></i> Adicionar Situação</button>
    </div>

    <!-- FILTRO -->
    <div class="input-group mb-3">
        <span class="input-group-text"><i class="bi bi-search"></i></span>
        <input type="text" class="form-control" placeholder="Pesquisar situação..." @bind="Filtro" @bind:event="oninput" />
    </div>

    <!-- TABELA -->
    <div class="card shadow-sm p-3">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Nome da Situação</th>
                        <th class="text-end pe-4">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in SituacoesFiltradas)
                    {
                        <tr>
                            <td>@s.ID</td>
                            <td>@s.Name</td>
                            <td class="text-end">

                                <button class="btn btn-sm btn-outline-primary me-1"
                                        @onclick="() => Editar(s.ID)">
                                    <i class="bi bi-pencil"></i>
                                </button>

                                <button class="btn btn-sm btn-outline-danger"
                                        @onclick="() => Excluir(s.ID)">
                                    <i class="bi bi-trash"></i>
                                </button>

                            </td>
                        </tr>
                    }

                    @if (!SituacoesFiltradas.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted py-4">
                                Nenhuma situação encontrada
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
       
    </div>

    <div class="mt-3 text-muted">
        Quantidade de Situações: @SituacoesFiltradas.Count()
    </div>


</div>

@code {

    private string Filtro = "";
    private List<SituationDTO> Situacoes = new();

    IEnumerable<SituationDTO> SituacoesFiltradas =>
        Situacoes.Where(s =>
            string.IsNullOrWhiteSpace(Filtro) ||
            (s.Name != null &&
             s.Name.Contains(Filtro, StringComparison.OrdinalIgnoreCase)));

    int TotalSituacoes => Situacoes?.Count ?? 0;

    void NovaSituacao()
        => Navigation.NavigateTo("/SA55");

    void Editar(int id)
        => Navigation.NavigateTo($"/SE64/{id}");

    async Task Excluir(int id)
    {
        bool confirmar = await JS.InvokeAsync<bool>(
            "confirm",
            "Deseja excluir esta Situação?"
        );

        if (confirmar)
        {
            await _service.DeleteSituation(id);
            Situacoes = await _service.SituationList();
            StateHasChanged();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        Situacoes = await _service.SituationList();
    }
}
