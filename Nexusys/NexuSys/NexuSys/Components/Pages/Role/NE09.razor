@page "/NE09/{Id:int}"
@using NexuSys.DTOs.Role
@using NexuSys.Helper
@using NexuSys.Interfaces
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject IUsers _service
@inject IUserContext UserContext

@if (IsLoading)
{
    <div class="loading-overlay">
        <div class="spinner-border text-light"></div>
        <p class="mt-3 text-light">Salvando...</p>
    </div>
}

<div class="container-fluid p-4">

    <h3 class="fw-bold mb-4">Editar Função</h3>

   
        <div class="card shadow-sm p-3">

            <fieldset disabled="@IsLoading">

                <div class="mb-3">
                    <label class="form-label">Nome</label>
                    <input class="form-control" @bind="Model.Name" />
                </div>

                <div class="d-flex justify-content-end">
                    <button class="btn btn-secondary me-2" @onclick="Voltar" disabled="@IsLoading">
                        Cancelar
                    </button>

                    <button class="btn btn-success" @onclick="Salvar" disabled="@IsLoading">
                        @(IsLoading ? "Salvando..." : "Salvar Alterações")
                    </button>
                </div>

            </fieldset>

        </div>
    </div>



@code {
    [Parameter] public int Id { get; set; }

    private ByRoleDTO Model = new();
    private bool IsLoading = false;

    protected override async Task OnInitializedAsync()
    {
        var role = await _service.RoleByID(Id);
        if (role != null)
        {
            Model.ID = role.ID;
            Model.Name = role.Name;
            Model.History = role.History;
            Model.CreateBy = role.CreateBy;
            Model.DateCreate = role.DateCreate;
        }
    }

    async Task Salvar()
    {
        if (IsLoading) return;
        IsLoading = true;

        Model.ChangedBy = UserContext.UserId;
        Model.DateChanged = DateTime.Now;

        var response = await _service.UpdateRole(Model);
        await JS.InvokeVoidAsync("alert", response.Result ? response.Message : response.Error);

        if (response.Result)
            Navigation.NavigateTo("/NF01");

        IsLoading = false;
    }

    void Voltar()
    {
        if (!IsLoading)
            Navigation.NavigateTo("/NF01");
    }
}