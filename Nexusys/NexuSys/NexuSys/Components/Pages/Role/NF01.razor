@page "/NF01"
@using NexuSys.DTOs.Role
@using NexuSys.Interfaces
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject IUsers _service
@inject IJSRuntime JS

<PageTitle>Funções</PageTitle>


<div class="container py-4 bg-white">

    <div class="d-flex justify-content-between align-items-start mb-4">

        <div>
            <h3 class="fw-bold mb-4 ">Funções</h3>
            <small class="text-muted">Gerencie o cadastro de funções</small>
        </div>

        <button class="btn btn-success" @onclick="NovaFuncao">
            <i class="bi bi-plus-circle"></i> Adicionar Função
        </button>
    </div>

    <div class="input-group mb-3">
        <span class="input-group-text "><i class="bi bi-search"></i></span>
        <input type="text" class="form-control" placeholder="Pesquisar função..." @bind="Filtro" @bind:event="oninput" />
    </div>

    <div class="card shadow-sm p-3">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Nome da Função</th>
                    <th class="text-end pe-4">Ações</th>
                </tr>
            </thead>
            <tbody>
                @if (FuncoesFiltradas.Any())
                {
                    @foreach (var role in FuncoesFiltradas)
                    {
                        <tr>
                            <td>@role.Name</td>
                            <td class="text-end pe-3">

                                <button class="btn btn-sm btn-outline-primary me-1"
                                        @onclick="() => Editar(role.ID)">
                                    <i class="bi bi-pencil"></i>
                                </button>

                                <button class="btn btn-sm btn-outline-danger me-2"
                                        @onclick="() => Excluir(role.ID)">
                                    <i class="bi bi-trash"></i>
                                </button>

                                <button class="btn btn-sm btn-outline-warning"
                                        title="Permissões"
                                        @onclick="() => IrParaPermissoes(role.ID)">
                                    <i class="bi bi-key"></i>
                                </button>

                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="2" class="text-center text-muted py-4">
                            Nenhuma função encontrada
                        </td>
                    </tr>
                }

            </tbody>
        </table>

    </div>

    <div class="mt-3 text-muted">
        Quantidade de serviços: @FuncoesFiltradas.Count()
    </div>

</div>

@code {

    private string Filtro = "";
    private List<RoleDTO> Funcoes = new();

    IEnumerable<RoleDTO> FuncoesFiltradas =>
    Funcoes.Where(r =>
    string.IsNullOrWhiteSpace(Filtro) ||
    r.Name.Contains(Filtro, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        Funcoes = await _service.RoleList();
    }

    void NovaFuncao()
    {
        Navigation.NavigateTo("/NA05");
    }

    void Editar(int id)
    {
        Navigation.NavigateTo($"/NE09/{id}");
    }


    void IrParaPermissoes(int id)
    {
        Navigation.NavigateTo($"/NR43/{id}");
    }

    async Task Excluir(int id)
    {
        bool confirmar = await JS.InvokeAsync<bool>(
        "confirm",
        "Deseja excluir esta função?"
        );

        if (confirmar)
        {
            await _service.DeleteRole(id);
            Funcoes = await _service.RoleList();
        }
    }
}