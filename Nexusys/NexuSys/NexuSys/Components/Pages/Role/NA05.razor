@page "/NA05"
@using NexuSys.DTOs.Role
@using NexuSys.Helper
@using NexuSys.Interfaces
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject IUsers _service
@inject IUserContext UserContext

<PageTitle>Nova Função</PageTitle>

@if (IsLoading)
{
    <div class="loading-overlay">
        <div class="spinner-border text-light" role="status"></div>
        <p class="mt-3 text-light fw-bold">Salvando função...</p>
    </div>
}

<EditForm Model="Model" OnValidSubmit="Salvar">

    <div class="container-fluid p-4">

        <h3 class="fw-bold mb-4">Nova Função</h3>
        <p class="text-muted">Preencha o campo abaixo para cadastrar uma nova Função</p>

        <div class="card">
            <div class="card-body">

                <fieldset disabled="@IsLoading">

                    <div class="mb-3">
                        <label class="form-label">Nome</label>
                        <InputText class="form-control"
                                   @bind-Value="Model.Name"
                                   placeholder="Digite aqui o nome da função" />
                    </div>

                    <div class="d-flex justify-content-end">
                        <button type="button"
                                class="btn btn-secondary me-2"
                                @onclick="Voltar"
                                disabled="@IsLoading">
                            Cancelar
                        </button>

                        <button class="btn btn-success"
                                type="submit"
                                disabled="@IsLoading">
                            @if (IsLoading)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                            
                            }
                            else
                            {
                                <span>Cadastrar Função</span>
                            }
                        </button>
                    </div>

                </fieldset>

            </div>
        </div>

    </div>
</EditForm>

@code {

    private NewRoleDTO Model = new();
    private bool IsLoading = false;

    async Task Salvar()
    {
        if (IsLoading)
            return;

        if (string.IsNullOrWhiteSpace(Model.Name))
        {
            await JS.InvokeVoidAsync("alert", "Informe o nome da função.");
            return;
        }

        IsLoading = true;
        StateHasChanged();

        Model.CreateBy = UserContext.UserId;
        Model.DateCreate = DateTime.Now;

        try
        {
            var response = await _service.NewRole(Model);

            if (response.Result)
            {
                await JS.InvokeVoidAsync("alert", response.Message);
                Navigation.NavigateTo("/NF01");
            }
            else
            {
                await JS.InvokeVoidAsync("alert", response.Error);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex);
            await JS.InvokeVoidAsync("alert", "Erro ao salvar a função.");
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    void Voltar()
    {
        if (!IsLoading)
            Navigation.NavigateTo("/NF01");
    }
}