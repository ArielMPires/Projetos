@page "/ND70"
@using NexuSys.DTOs.Departament
@using NexuSys.Interfaces
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject IUsers _service
@inject IJSRuntime JS

<PageTitle>Departamentos</PageTitle>

<div class="container py-4 bg-white">

    <div class="d-flex justify-content-between align-items-start mb-4">

        <div>
        <h3 class="fw-bold">Departamentos</h3>
        <small class="text-muted">Gerencie o cadastro de departamentos</small>
        </div>

        <button class="btn btn-success" @onclick="NovoDepartamento">
            <i class="bi bi-plus-circle"></i> Adicionar Departamento
        </button>
    </div>
    
    <!-- PESQUISA -->
    <div class="input-group mb-3 ">
        <span class="input-group-text"><i class="bi bi-search"></i></span>
        <input class="form-control" placeholder="Pesquisar departamento..."  @bind="Filtro" @bind:event="oninput" />
    </div>


    <div class="card shadow-sm p-3">
    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Nome dos Departamentos</th>
                <th class="text-end pe-4">Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var dep in DepartamentosFiltrados)
            {
                <tr>
                    <td>@dep.Name</td>
                        <td class="text-end pe-3">
                        <button class="btn btn-sm btn-outline-primary me-1"
                                @onclick="() => Editar(dep.ID)">
                            <i class="bi bi-pencil"></i>
                        </button>

                        <button class="btn btn-sm btn-outline-danger"
                                @onclick="() => Excluir(dep.ID)">
                            <i class="bi bi-trash"></i>
                        </button>
                    </td>
                </tr>
            }

            @if (!DepartamentosFiltrados.Any())
            {
                <tr>
                    <td colspan="2" class="text-center text-muted py-4">
                        Nenhum departamento encontrado
                    </td>
                </tr>
            }
        </tbody>
    </table>

    </div>
    <div class="mt-3 text-muted">
        Quantidade de Departamentos: @DepartamentosFiltrados.Count()
    </div>

</div>

@code {

    string Filtro = "";

    private List<DepartamentDTO> Departamentos = new();

    IEnumerable<DepartamentDTO> DepartamentosFiltrados =>
        Departamentos.Where(d =>
            string.IsNullOrWhiteSpace(Filtro) ||
            d.Name.Contains(Filtro, StringComparison.OrdinalIgnoreCase));

    void NovoDepartamento() => Navigation.NavigateTo("/NA44");
    void Editar(int id) => Navigation.NavigateTo($"/NE81/{id}");
    async void Excluir(int id)
    {
        bool confirmar = await JS.InvokeAsync<bool>("confirm", "Deseja excluir este Departamento?");
        if (confirmar)
        {
            await _service.DeleteDepartament(id);
            Departamentos.RemoveAll(e => e.ID == id);
        }

        StateHasChanged();
    }

    protected override async Task OnInitializedAsync()
    {
        Departamentos = await _service.DepartamentList();
    }

}
