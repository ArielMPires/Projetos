@page "/NA44"
@using NexuSys.DTOs.Departament
@using NexuSys.Helper
@using NexuSys.Interfaces
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject IUsers _service
@inject IUserContext UserContext

<PageTitle>Novo Departamento</PageTitle>

@if (IsLoading)
{
    <div class="loading-overlay">
        <div class="spinner-border text-light" role="status"></div>
        <p class="mt-3 text-light fw-bold">Salvando departamento...</p>
    </div>
}

<div class="container p-4">

    <h3 class="mb-4">Novo Departamento</h3>
    <p class="text-muted">Preencha o campo abaixo para cadastrar um novo Departamento</p>

    <EditForm Model="Model" OnValidSubmit="Salvar">

        <fieldset disabled="@IsLoading">

            <div class="mb-3">
                <label class="form-label">Nome do Departamento</label>
                <InputText class="form-control"
                           @bind-Value="Model.Name"
                           placeholder="Digite o nome do Departamento" />
            </div>

            <div class="d-flex justify-content-end gap-2">
                <button class="btn btn-secondary"
                        type="button"
                        @onclick="Voltar"
                        disabled="@IsLoading">
                    Voltar
                </button>

                <button class="btn btn-success"
                        type="submit"
                        disabled="@IsLoading">
                    @if (IsLoading)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                 
                    }
                    else
                    {
                        <span>Cadastrar Departamento</span>
                    }
                </button>
            </div>

        </fieldset>

    </EditForm>

</div>

@code {

    private NewDepartamentDTO Model = new();
    private bool IsLoading = false;

    async Task Salvar()
    {
        if (IsLoading)
            return;

        if (string.IsNullOrWhiteSpace(Model.Name))
        {
            await JS.InvokeVoidAsync("alert", "Informe o nome do departamento.");
            return;
        }

        IsLoading = true;
        StateHasChanged();

        Model.CreateBy = UserContext.UserId;
        Model.DateCreate = DateTime.Now;

        try
        {
            var response = await _service.NewDepartament(Model);

            if (response.Result)
            {
                await JS.InvokeVoidAsync("alert", response.Message);
                Navigation.NavigateTo("/ND70");
            }
            else
            {
                await JS.InvokeVoidAsync("alert", response.Error);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex);
            await JS.InvokeVoidAsync("alert", "Erro ao salvar o departamento.");
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    void Voltar()
    {
        if (!IsLoading)
            Navigation.NavigateTo("/ND70");
    }
}