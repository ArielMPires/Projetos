@page "/NT03/{id:int}"
@using NexuSys.DTOs.Type_Service
@using NexuSys.Helper
@using NexuSys.Interfaces
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject IService _service
@inject IJSRuntime JS
@inject IUserContext UserContext

@if (IsLoading)
{
    <div class="loading-overlay">
        <div class="spinner-border text-light"></div>
        <p class="mt-3 text-light">Salvando alterações...</p>
    </div>
}

<div class="container py-4 bg-white">
    <h3 class="fw-bold mb-4">Editar Serviço</h3>

    <div class="card shadow-sm p-3">
        <fieldset disabled="@IsLoading">

            <div class="mb-3">
                <label class="form-label">Nome do Serviço</label>
                <InputText class="form-control" @bind-Value="Model.Name" />
            </div>

            <div class="d-flex justify-content-end">
                <button class="btn btn-secondary me-2" @onclick="Voltar" disabled="@IsLoading">
                    Cancelar
                </button>

                <button class="btn btn-success" @onclick="Salvar" disabled="@IsLoading">
                    @(IsLoading ? "Salvando..." : "Salvar Alterações")
                </button>
            </div>

        </fieldset>
    </div>
</div>

@code {
    [Parameter] public int Id { get; set; }

    private ByType_ServiceDTO Model = new();
    private bool IsLoading = false;

    protected override async Task OnInitializedAsync()
    {
        var types = await _service.Type_ServiceByID(Id);
        Model.Name = types.Name;
        Model.ID = types.ID;
        Model.History = types.History;
        Model.CreateBy = types.CreateBy;
        Model.DateCreate = types.DateCreate;
    }

    async Task Salvar()
    {
        if (IsLoading) return;
        IsLoading = true;

        Model.CreateBy = UserContext.UserId;
        Model.DateCreate = DateTime.Now;
        Model.ChangedBy = UserContext.UserId;
        Model.DateChanged = DateTime.Now;

        var response = await _service.UpdateType_Service(Model);
        await JS.InvokeVoidAsync("alert", response.Result ? response.Message : response.Error);

        if (response.Result)
            Navigation.NavigateTo("/NT01");

        IsLoading = false;
    }

    void Voltar()
    {
        if (!IsLoading)
            Navigation.NavigateTo("/NT01");
    }
}