@page "/NT01"
@using NexuSys.DTOs.Type_Service
@using NexuSys.Helper
@using NexuSys.Interfaces
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject IService _service
@inject IUserContext UserContext

<PageTitle>Tipos de Serviço</PageTitle>

<div class="container py-4 bg-white">
    <div class="d-flex justify-content-between align-items-center mb-4">

    <div>
        <h3 class="fw-bold">Tipos de Serviços</h3>
        <small class="text-muted">Gerencie o cadastro de tipos de serviços</small>
    </div>

     <!-- Botões de Adicionar serviço -->
        <button class="btn btn-success" @onclick="Adicionar">
            <i class="bi bi-plus-circle"></i> Adicionar Serviço
        </button>
    </div>

    <!-- Área de Pesquisa -->
    <div class="input-group mb-3 ">
        <span class="input-group-text"><i class="bi bi-search"></i></span>
        <input type="text" class="form-control w-50" placeholder="Pesquisar serviço..." @bind="Filtro" @bind:event="oninput" @onclick="Pesquisar"/>
    </div>

    <!-- Tabela de Serviços -->
    <div class="card shadow-sm p-3">
        <table class="table align-middle">
            <thead class="table-light p-0 align-middle">
                <tr>
                    <th>Nome do Serviço</th>
                    <th class="text-end pe-4">Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var servico in TiposdeServicoFiltrados)
                {
                    <tr>
                        <td>@servico.Name</td>
                        <td class="text-end pe-3">
                            <button class="btn btn-sm btn-outline-primary me-1"
                                    @onclick="() => Editar(servico.ID)">
                                <i class="bi bi-pencil"></i> 
                            </button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => Excluir(servico.ID)">
                                <i class="bi bi-trash"></i> 
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
     </div>

    <div class="mt-3 text-muted">
        Quantidade de serviços: @TiposdeServicoFiltrados.Count()
    </div>

    </div>
    


@code {
    string Filtro = "";

    private List<Type_ServiceDTO> TiposdeServico = new();

    IEnumerable<Type_ServiceDTO> TiposdeServicoFiltrados =>
        TiposdeServico.Where(d =>
            string.IsNullOrWhiteSpace(Filtro) ||
            d.Name.Contains(Filtro, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        TiposdeServico = await _service.Type_ServiceList();
    }

    private void Pesquisar()
    {
        StateHasChanged();
    }

    private async void Excluir(int id)
    {
        bool confirmar = await JS.InvokeAsync<bool>("confirm", "Deseja excluir este Tipo de Serviço?");
        if (confirmar)
        {
            await _service.DeleteType_Service(id);
            TiposdeServico = await _service.Type_ServiceList();
            StateHasChanged();
        }
    }


    private string RemoverAcentos(string texto)
    {
        if (string.IsNullOrWhiteSpace(texto)) return string.Empty;
        return new string(texto
            .Normalize(System.Text.NormalizationForm.FormD)
            .Where(ch => System.Globalization.CharUnicodeInfo.GetUnicodeCategory(ch) != System.Globalization.UnicodeCategory.NonSpacingMark)
            .ToArray());
    }

    void Editar(int id) => Navigation.NavigateTo($"/NT03/{id}");

    void Adicionar()
    {
        Navigation.NavigateTo("/NT02");
    }

}