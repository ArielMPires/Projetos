@page "/NU57"
@using NexuSys.DTOs.Unit
@using NexuSys.Interfaces
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject IUsers _service
@inject IJSRuntime JS

<PageTitle>Unidades</PageTitle>

<div class="container py-4 bg-white">

    <div class="d-flex justify-content-between align-items-center mb-3">

        <div>
            <h3 class="fw-bold">Unidades</h3>
            <small class="text-muted">Gerencie o cadastro de unidades</small>
        </div>

        <button class="btn btn-success" @onclick="NovaUnidade">
            <i class="bi bi-plus-circle"></i> Adicionar Unidade
        </button>

    </div>

    <div class="input-group mb-3 ">
        <span class="input-group-text"><i class="bi bi-search"></i></span>
        <input type="text" class="form-control"placeholder="Pesquisar unidade..." @bind="Filtro" @bind:event="oninput" />
    </div>


    <div class="card shadow-sm p-3">
    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Nome das Unidades</th>
                <th class="text-end pe-4">Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var un in UnidadesFiltradas)
            {
                <tr>
                    <td>@un.Name</td>
                        <td class="text-end pe-3">

                        <button class="btn btn-sm btn-outline-primary me-1"
                                @onclick="() => Editar(un.ID)">
                            <i class="bi bi-pencil"></i>
                        </button>

                        <button class="btn btn-sm btn-outline-danger"
                                @onclick="() => Excluir(un.ID)">
                            <i class="bi bi-trash"></i>
                        </button>

                    </td>
                </tr>
            }

            @if (!UnidadesFiltradas.Any())
            {
                <tr>
                    <td colspan="2" class="text-center text-muted py-4">
                        Nenhuma unidade encontrada
                    </td>
                </tr>
            }
        </tbody>
    </table>
    </div>

    <div class="mt-3 text-muted">
        Quantidade de Unidades: @UnidadesFiltradas.Count()
    </div>

</div>

@code {

    string Filtro = "";
    private List<UnitDTO> Unidades = new();

    IEnumerable<UnitDTO> UnidadesFiltradas =>
        Unidades.Where(u =>
            string.IsNullOrWhiteSpace(Filtro) ||
            u.Name.Contains(Filtro, StringComparison.OrdinalIgnoreCase));

    int TotalUnidades => Unidades.Count;

    void NovaUnidade() => Navigation.NavigateTo("/NA60");
    void Editar(int id) => Navigation.NavigateTo($"/NE40/{id}");

    async Task Excluir(int id)
    {
        bool confirmar = await JS.InvokeAsync<bool>("confirm", "Deseja excluir esta Unidade?");

        if (confirmar)
        {
            await _service.DeleteUnit(id);
            Unidades = await _service.UnitList();
            StateHasChanged();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        Unidades = await _service.UnitList();
    }
}
