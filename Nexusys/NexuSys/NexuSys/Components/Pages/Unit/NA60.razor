@page "/NA60"
@using NexuSys.DTOs.Unit
@using NexuSys.Helper
@using NexuSys.Interfaces
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject IUsers _service
@inject IUserContext UserContext

<PageTitle>Nova Unidade</PageTitle>

@if (IsLoading)
{
    <div class="loading-overlay">
        <div class="spinner-border text-light" role="status"></div>
        <p class="mt-3 text-light fw-bold">Salvando unidade...</p>
    </div>
}

<div class="container p-4">

    <h3 class="mb-2">Nova Unidade</h3>
    <p class="text-muted">Preencha o campo abaixo para cadastrar uma nova Unidade</p>

    <div class="card shadow-sm p-4 mt-3">

        <EditForm Model="Model" OnValidSubmit="Salvar">

            <fieldset disabled="@IsLoading">

                <div class="mb-3">
                    <label class="form-label">Nome da Unidade</label>
                    <InputText class="form-control"
                               @bind-Value="Model.Name"
                               placeholder="Digite o nome da Unidade" />
                </div>

                <div class="d-flex justify-content-end gap-2 mt-4">
                    <button type="button"
                            class="btn btn-secondary"
                            @onclick="Voltar"
                            disabled="@IsLoading">
                        Voltar
                    </button>

                    <button type="submit"
                            class="btn btn-success"
                            disabled="@IsLoading">
                        @if (IsLoading)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                            
                        }
                        else
                        {
                            <span>Cadastrar Unidade</span>
                        }
                    </button>
                </div>

            </fieldset>

        </EditForm>

    </div>

</div>

@code {

    private NewUnitDTO Model = new();
    private bool IsLoading = false;

    async Task Salvar()
    {
        if (IsLoading)
            return;

        IsLoading = true;
        StateHasChanged();

        Model.CreateBy = UserContext.UserId;
        Model.DateCreate = DateTime.Now;

        try
        {
            var response = await _service.NewUnit(Model);

            if (response.Result)
            {
                await JS.InvokeVoidAsync("alert", response.Message);
                Navigation.NavigateTo("/NU57");
            }
            else
            {
                await JS.InvokeVoidAsync("alert", response.Error);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex);
            await JS.InvokeVoidAsync("alert", "Erro ao cadastrar a unidade.");
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    void Voltar()
    {
        if (!IsLoading)
            Navigation.NavigateTo("/NU57");
    }
}