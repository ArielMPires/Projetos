@page "/NE40/{Id:int}"
@using NexuSys.DTOs.Unit
@using NexuSys.Helper
@using NexuSys.Interfaces
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject IUsers _service
@inject IJSRuntime JS
@inject IUserContext UserContext

@if (IsLoading)
{
    <div class="loading-overlay">
        <div class="spinner-border text-light"></div>
        <p class="mt-3 text-light">Salvando...</p>
    </div>
}

<div class="container py-4 bg-white">

    <h3 class="fw-bold mb-4">Editar Unidade</h3>

   
        <div class="card shadow-sm p-3">

    <EditForm Model="Model" OnValidSubmit="Salvar">
        <fieldset disabled="@IsLoading">

            <div class="mb-3">
                <label class="form-label">Nome da Unidade</label>
                <InputText class="form-control" @bind-Value="Model.Name" />
            </div>

            <div class="d-flex justify-content-end">
                <button class="btn btn-secondary me-2" type="button" @onclick="Voltar" disabled="@IsLoading">
                    Cancelar
                </button>

                <button class="btn btn-success" type="submit" disabled="@IsLoading">
                    @(IsLoading ? "Salvando..." : "Salvar Alterações")
                </button>
            </div>

        </fieldset>
    </EditForm>
      </div>
 </div>


@code {
    [Parameter] public int Id { get; set; }

    private ByUnitDTO Model = new();
    private bool IsLoading = false;

    protected override async Task OnInitializedAsync()
    {
        Model = await _service.UnitByID(Id);
    }

    async Task Salvar()
    {
        if (IsLoading) return;
        IsLoading = true;


        Model.ChangedBy = UserContext.UserId;
        Model.DateChanged = DateTime.Now;

        var response = await _service.UpdateUnit(Model);
        await JS.InvokeVoidAsync("alert", response.Result ? response.Message : response.Error);

        if (response.Result)
            Navigation.NavigateTo("/NU57");

        IsLoading = false;
    }

    void Voltar()
    {
        if (!IsLoading)
            Navigation.NavigateTo("/NU57");
    }
}