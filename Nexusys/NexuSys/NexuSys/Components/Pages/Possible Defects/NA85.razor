@page "/NA85"
@using NexuSys.DTOs.Possible_Defects
@using NexuSys.Helper
@using NexuSys.Interfaces
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject IBudget _service
@inject IUserContext UserContext

<PageTitle>Novo Defeito</PageTitle>

@if (IsLoading)
{
    <div class="loading-overlay">
        <div class="spinner-border text-light" role="status"></div>
        <p class="mt-3 text-light fw-bold">Salvando defeito...</p>
    </div>
}

<div class="container-fluid p-4">

    <h3 class="fw-bold mb-4">Cadastrar Possível Defeito</h3>
    <p class="text-muted">Preencha o campo abaixo para cadastrar um novo Possível Defeito</p>

    <EditForm Model="Model" OnValidSubmit="Salvar">

        <div class="card">
            <div class="card-body">

                <fieldset disabled="@IsLoading">

                    <div class="mb-3">
                        <label class="form-label">Nome do Defeito</label>
                        <InputText class="form-control"
                                   @bind-Value="Model.Name"
                                   placeholder="Digite aqui o nome do possível defeito" />
                    </div>

                    <div class="d-flex justify-content-end">
                        <button type="button"
                                class="btn btn-secondary me-2"
                                @onclick="Voltar"
                                disabled="@IsLoading">
                            Cancelar
                        </button>

                        <button type="submit"
                                class="btn btn-success"
                                disabled="@IsLoading">
                            @if (IsLoading)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                         
                            }
                            else
                            {
                                <span>Cadastrar Produto</span>
                            }
                        </button>
                    </div>

                </fieldset>

            </div>
        </div>

    </EditForm>

</div>

@code {

    private NewPossible_DefectsDTO Model = new();
    private bool IsLoading = false;

    async Task Salvar()
    {
        if (IsLoading)
            return;

        if (string.IsNullOrWhiteSpace(Model.Name))
        {
            await JS.InvokeVoidAsync("alert", "Informe o nome do defeito.");
            return;
        }

        IsLoading = true;
        StateHasChanged();

        Model.CreateBy = UserContext.UserId;
        Model.DateCreate = DateTime.Now;

        try
        {
            var response = await _service.NewPossible_Defects(Model);

            if (response.Result)
            {
                await JS.InvokeVoidAsync("alert", response.Message);
                Navigation.NavigateTo("/NP65");
            }
            else
            {
                await JS.InvokeVoidAsync("alert", response.Message);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex);
            await JS.InvokeVoidAsync("alert", "Erro ao cadastrar o defeito.");
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    void Voltar()
    {
        if (!IsLoading)
            Navigation.NavigateTo("/NP65");
    }
}