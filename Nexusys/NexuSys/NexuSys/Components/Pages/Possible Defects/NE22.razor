@page "/NE22/{Id:int}"
@using NexuSys.DTOs.Possible_Defects
@using NexuSys.Helper
@using NexuSys.Interfaces
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject IBudget _service
@inject IUserContext UserContext

@if (IsLoading)
{
    <div class="loading-overlay">
        <div class="spinner-border text-light"></div>
        <p class="mt-3 text-light">Salvando...</p>
    </div>
}

<div class="container py-4 bg-white">

    <h3 class="fw-bold mb-4">Editar Possível Defeito</h3>

   
        <div class="card shadow-sm p-3">

            <fieldset disabled="@IsLoading">

                <div class="mb-3">
                    <label class="form-label">Nome do Defeito</label>
                    <input class="form-control" @bind="Model.Name" />
                </div>

                <div class="d-flex justify-content-end">
                    <button class="btn btn-secondary me-2" @onclick="Voltar" disabled="@IsLoading">
                        Cancelar
                    </button>

                    <button class="btn btn-success" @onclick="Salvar" disabled="@IsLoading">
                        @(IsLoading ? "Salvando..." : "Salvar Alterações")
                    </button>
                </div>

            </fieldset>

        </div>
    </div>



@code {
    [Parameter] public int Id { get; set; }

    private EditPossible_DefectsDTO Model = new();
    private bool IsLoading = false;

    protected override async Task OnInitializedAsync()
    {
        var defect = await _service.Possible_DefectsByID(Id);

        if (defect != null)
        {
            Model.ID = defect.ID;
            Model.Name = defect.Name;
            Model.History = defect.History;
            Model.CreateBy = defect.CreateBy;
            Model.DateCreate = defect.DateCreate;
        }
    }

    async Task Salvar()
    {
        if (IsLoading) return;
        IsLoading = true;

        Model.CreateBy = UserContext.UserId;
        Model.DateCreate = DateTime.Now;
        Model.ChangedBy = UserContext.UserId;
        Model.DateChanged = DateTime.Now;

        var response = await _service.UpdatePossible_Defects(Model);
        await JS.InvokeVoidAsync("alert", response.Result ? response.Message : response.Error);

        if (response.Result)
            Navigation.NavigateTo("/NP65");

        IsLoading = false;
    }

    void Voltar()
    {
        if (!IsLoading)
            Navigation.NavigateTo("/NP65");
    }
}