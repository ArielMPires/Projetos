<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:Agnus.ViewModels"
             x:Class="Agnus.Views.SS159"
             Title="">

    <Grid Padding="1">
        <HorizontalStackLayout>
            <Button
            IsVisible="{OnPlatform Android=true, iOS=true, WinUI=false}"
            Command="{Binding _ReturnCommand}"
            TextColor="#0078D7"
            Padding="10"
            HorizontalOptions="StartAndExpand"
            VerticalOptions="Start"
            Margin="10">
                <Button.ImageSource>
                    <FontImageSource Glyph="&#xf060;" FontFamily="FontAwesomeSolid" Size="24"/>
                </Button.ImageSource>
            </Button>
            <Label Text="SS159"
               FontSize="20"
               Opacity="0.3"
               Rotation="0"
               TextColor="Gray"
               HorizontalOptions="End"
               VerticalOptions="End"
               InputTransparent="True"/>
        </HorizontalStackLayout>
        <Label Margin="10" Text="Novo Usuario" HorizontalOptions="Center" FontSize="28" FontAttributes="Bold"/>
        <ScrollView Margin="50">
            <Grid RowDefinitions="*,*" ColumnDefinitions="*,auto" >
                <Border Grid.Column="0" Padding="10" Margin="10">
                    <VerticalStackLayout Padding="10">
                    <Label Text="Informações" FontAttributes="Bold" FontSize="24" HorizontalOptions="Center"/>
                        <Label Text="Nome:" FontAttributes="Italic"/>
                        <Entry  Placeholder="Nome" Text="{Binding _user.Name}"/>
                        <BoxView Margin="10"/>
                        <Label Text="Senha:" FontAttributes="Italic"/>
                        <Entry  Placeholder="Senha" IsPassword="True" Text="{Binding _user.Password}"/>
                        <BoxView Margin="10"/>
                        <Label Text="Email:" FontAttributes="Italic"/>
                        <Entry  Placeholder="Email" Text="{Binding _user.Email}"/>
                        <BoxView Margin="30"/>
                        <Button Text="Enviar" Command="{Binding _NewUserCommand}" IsEnabled="{Binding IsNotBusy}" HorizontalOptions="Center" WidthRequest="200"/>
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Column="{OnPlatform Android=0,WinUI=1}" Grid.Row="{OnPlatform Android=1,WinUI=0}" Padding="10" Margin="10">
                    <VerticalStackLayout Padding="10">
                        <Label Text="Informações Extras" FontAttributes="Bold" FontSize="24" HorizontalOptions="Center" />
                        <Label Text="Função:" FontAttributes="Italic"/>
                        <Picker  ItemsSource="{Binding Roles}" ItemDisplayBinding="{Binding Name}" SelectedItem="{Binding _SelectedRole}"/>
                        <BoxView Margin="10"/>
                        <Label Text="Departamento:" FontAttributes="Italic"/>
                        <Picker  ItemsSource="{Binding Departments}" ItemDisplayBinding="{Binding Name}" SelectedItem="{Binding _SelectedDept}"/>
                        <BoxView Margin="10"/>
                        <Grid HorizontalOptions="Center" ColumnDefinitions="auto,*" RowDefinitions="*,*">
                            <VerticalStackLayout Margin="10" HorizontalOptions="Center" Grid.Column="0" Grid.Row="0">
                                <Button Text="Selecionar Foto de Perfil"  Command="{Binding _SelectImagePerfilCommand}" Margin="3" Grid.Column="0">
                                    <Button.ImageSource>
                                        <FontImageSource Glyph="&#xf2c2;" FontFamily="FontAwesomeSolid" Size="24"/>
                                    </Button.ImageSource>
                                </Button>
                                <Border Style="{StaticResource Round}">
                                    <Image WidthRequest="100" HeightRequest="100" Aspect="AspectFit" Source="{Binding ImagemPerfil}" Grid.Column="0"/>
                                </Border>
                            </VerticalStackLayout>
                            <VerticalStackLayout Margin="10" HorizontalOptions="Center" Grid.Column="{OnPlatform Android=0,WinUI=1}" Grid.Row="{OnPlatform Android=1,WinUI=0}">
                                <Button Text="Selecionar Assinatura" Command="{Binding _SelectImageAssCommand}" Grid.Column="1" Margin="3">
                                    <Button.ImageSource>
                                        <FontImageSource Glyph="&#xf573;" FontFamily="FontAwesomeSolid" Size="24"/>
                                    </Button.ImageSource>
                                </Button>
                                <Border Style="{StaticResource Round}">
                                    <Image WidthRequest="100" HeightRequest="100" Aspect="AspectFit" Source="{Binding ImagemAss}" Grid.Column="1"/>
                                </Border>
                            </VerticalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Border>
            </Grid>
        </ScrollView>
    </Grid>
</ContentPage>