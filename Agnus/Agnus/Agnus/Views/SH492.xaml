<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:Agnus.ViewModels"
             x:Class="Agnus.Views.SH492"
             Title="">

    <Grid Padding="1">
        <HorizontalStackLayout>
            <Button
            IsVisible="{OnPlatform Android=true, iOS=true, WinUI=false}"
            Command="{Binding _ReturnCommand}"
            TextColor="#0078D7"
            Padding="10"
            HorizontalOptions="StartAndExpand"
            VerticalOptions="Start"
            Margin="10">
                <Button.ImageSource>
                    <FontImageSource Glyph="&#xf060;" FontFamily="FontAwesomeSolid" Size="24"/>
                </Button.ImageSource>
            </Button>
            <Label Text="SH492"
               FontSize="20"
               Opacity="0.3"
               Rotation="0"
               TextColor="Gray"
               HorizontalOptions="End"
               VerticalOptions="End"
               InputTransparent="True"/>
        </HorizontalStackLayout>
        <Label Margin="10" Text="{Binding Order.ID,StringFormat='Pedido de Compra Nº{0}'}" HorizontalOptions="Center" FontSize="28" FontAttributes="Bold"/>
        <ScrollView Margin="50" IsVisible="{Binding IsInfo}">
            <Grid RowDefinitions="*,*" ColumnDefinitions="*,auto" >
                <Border Grid.Column="0" Padding="10" Margin="10">
                    <VerticalStackLayout Padding="10">
                        <Label Text="Informações" FontAttributes="Bold" FontSize="24" HorizontalOptions="Center"/>
                        <Label Text="Numero da Solicitação:" FontAttributes="Italic"/>
                        <Entry  Text="{Binding Order.Request}" IsReadOnly="True"/>
                        <BoxView Margin="10"/>
                        <Label Text="Fornecedor Sugerido:" FontAttributes="Italic"/>
                        <Entry  Text="{Binding Order.SupplierFK.Name}"/>
                        <BoxView Margin="10"/>
                        <Label Text="Situação:" FontAttributes="Italic"/>
                        <Entry  Placeholder="Situação" Text="{Binding Order.Situation}"/>
                        <BoxView Margin="10"/>
                        <Label Text="Prazo de Entrega:" FontAttributes="Italic"/>
                        <DatePicker  Date="{Binding Order.Delivery_Time}"/>
                        <BoxView Margin="10"/>
                        <Button Text="Enviar" Command="{Binding _EditRequestCommand}" IsEnabled="{Binding IsNotBusy}" HorizontalOptions="Center" WidthRequest="200"/>
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Column="{OnPlatform Android=0,WinUI=1}" Grid.Row="{OnPlatform Android=1,WinUI=0}" Padding="10" Margin="10">
                    <VerticalStackLayout Padding="10">
                        <Button 
            Command="{Binding TrocarAbaCommand}" CommandParameter="InfoAdd"
            TextColor="#0078D7"
            Padding="10"
            HorizontalOptions="End"
            VerticalOptions="End"
             Style="{StaticResource Circle}"
            Margin="10"
            x:Name="FabBtn">
                            <Button.ImageSource>
                                <FontImageSource Glyph="&#xf481;" Color="White" FontFamily="FontAwesomeSolid" Size="24"/>
                            </Button.ImageSource>
                        </Button>
                        <CollectionView ItemsSource="{Binding Items}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <StackLayout Padding="10" Spacing="5" BackgroundColor="Transparent">
                                        <Frame>
                                            <Grid ColumnDefinitions="*,*,*" HeightRequest="50" RowDefinitions="*,*">
                                                <Label Text="{Binding value.Product,StringFormat='Cod. {0}'}" Grid.Column="0" Grid.Row="0" FontSize="18" HorizontalOptions="Start" VerticalOptions="Center"/>
                                                <Label Text="{Binding value.ProductFK.Description, StringFormat='{0} - '}" Grid.Column="0" Grid.Row="1" FontSize="18" HorizontalOptions="Start" VerticalOptions="Center"/>
                                                <Label Text="{Binding value.Amount, StringFormat=' {0}Pçs'}" Grid.Column="1" Grid.Row="1" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center"/>
                                                <Button
                                                    Grid.Column="
                                                    2"
                                                    HorizontalOptions="End"
                                                    BackgroundColor="Transparent"                                  
                                                    Padding="1"                                        
                                                    Margin="2"                                       
                                                    WidthRequest="50"                                        
                                                    Style="{StaticResource Circle}"                                        
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext._commandDelItem}"                                        
                                                    CommandParameter="{Binding ID}">
                                                    <Button.ImageSource>
                                                        <FontImageSource Glyph="&#xf00d;" FontFamily="FontAwesomeSolid" Size="24" Color="Red"/>
                                                    </Button.ImageSource>
                                                </Button>
                                            </Grid>
                                        </Frame>
                                    </StackLayout>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>
            </Grid>
        </ScrollView>
        <Grid IsVisible="{Binding IsInfoAdd}" VerticalOptions="Center">
            <Border Padding="10" Margin="10">
                <VerticalStackLayout Spacing="15">
                    <Label Text="NF:" FontAttributes="Italic"/>
                    <Entry  Placeholder="NF" Text="{Binding NF.Numero}" Keyboard="Numeric"/>
                    <Label Text="Fornecedor:" FontAttributes="Italic"/>
                    <Picker ItemsSource="{Binding Supplier}" ItemDisplayBinding="{Binding Name}" SelectedItem="{Binding _SelectedSupplier}"/>
                    <CollectionView ItemsSource="{Binding Items}">
                        <CollectionView.Header>
                            <Border Padding="10" Margin="4" Style="{StaticResource HeaderBorder}">
                                <Grid ColumnDefinitions="2*,2*,3*,3*,6*,3*">
                                    <Label Text="#" Grid.Column="0" FontSize="25" FontAttributes="Bold" HorizontalOptions="Center" Style="{StaticResource HeaderText}" />
                                    <Label Text="Cod." Grid.Column="1" FontSize="25" FontAttributes="Bold" HorizontalOptions="Center" Style="{StaticResource HeaderText}" />
                                    <Label Text="Descrição" Grid.Column="2" FontSize="25" FontAttributes="Bold" HorizontalOptions="Center" Style="{StaticResource HeaderText}" />
                                    <Label Text="Quantidade" Grid.Column="3" FontSize="25" FontAttributes="Bold" HorizontalOptions="Center" Style="{StaticResource HeaderText}" />
                                    <Label Text="Valor Unitario" Grid.Column="4" FontSize="25" FontAttributes="Bold" HorizontalOptions="Center" Style="{StaticResource HeaderText}" />

                                </Grid>
                            </Border>
                        </CollectionView.Header>
                        <CollectionView.ItemsLayout>
                            <GridItemsLayout Orientation="Vertical" Span="1"/>
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="5" Margin="4">
                                    <Grid ColumnDefinitions="2*,2*,3*,3*,6*,3*" HeightRequest="50">
                                        <CheckBox IsChecked="{Binding IsChecked}"/>
                                        <Label Text="{Binding value.ProductFK.ID}" Grid.Column="1" HorizontalOptions="Center" VerticalOptions="Center"/>
                                        <Label Text="{Binding value.ProductFK.Description}" Grid.Column="2" HorizontalOptions="Center" VerticalOptions="Center"/>
                                        <Label Text="{Binding value.Amount}" Grid.Column="3" HorizontalOptions="Center" VerticalOptions="Center"/>
                                        <Entry Text="{Binding value.Unit_Value}" FontSize="16" Background="Transparent" TextColor="{AppThemeBinding Light=Black,Dark=White}" Grid.Column="4" HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                    <HorizontalStackLayout HorizontalOptions="Center">
                        <Button Text="Enviar" Command="{Binding _commandEntry}" HorizontalOptions="Center" WidthRequest="200"/>
                        <BoxView Margin="10"/>
                        <Button Text="Cancelar" Command="{Binding TrocarAbaCommand}" BackgroundColor="Red" CommandParameter="Information" HorizontalOptions="Center" WidthRequest="200"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>