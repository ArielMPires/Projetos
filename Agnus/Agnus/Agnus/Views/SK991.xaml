<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:Agnus.ViewModels"
             x:Class="Agnus.Views.SK991"
             Title="">

    <Grid Padding="10">

        <!-- Cabeçalho -->
        <HorizontalStackLayout>
            <Button
                IsVisible="{OnPlatform Android=true, iOS=true, WinUI=false}"
                Command="{Binding _ReturnCommand}"
                TextColor="#0078D7"
                Padding="10"
                HorizontalOptions="StartAndExpand"
                VerticalOptions="Start"
                Margin="10">
                <Button.ImageSource>
                    <FontImageSource Glyph="&#xf060;" FontFamily="FontAwesomeSolid" Size="24"/>
                </Button.ImageSource>
            </Button>

            <Label Text="SK991"
                   FontSize="20"
                   Opacity="0.4"
                   TextColor="Gray"
                   HorizontalOptions="End"
                   VerticalOptions="End"
                   InputTransparent="True"/>
        </HorizontalStackLayout>

        <!-- Conteúdo -->
        <ScrollView>
            <StackLayout Padding="20" Margin="10,50,10,0" VerticalOptions="Start">

              
                <Grid ColumnDefinitions="*,*" ColumnSpacing="20">

                
                    <Border Grid.Column="0" Padding="10" Margin="10">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Informações do Produto" FontAttributes="Bold" FontSize="24" HorizontalOptions="Center" />
                            <Label Text="Produto:" FontAttributes="Italic"/>
                            <Entry Placeholder="Descrição do Produto" 
                                   Text="{Binding _product.Description}"/>
                            <Label Text="Categoria:" FontAttributes="Italic"/>
                            <Picker
                                    ItemsSource="{Binding Category}" 
                                    ItemDisplayBinding="{Binding Name}" 
                                    SelectedItem="{Binding _SelectCategory}"/>
                            <Label Text="Marca:" FontAttributes="Italic"/>
                            <Picker
                                    ItemsSource="{Binding Brands}" 
                                    ItemDisplayBinding="{Binding Name}" 
                                    SelectedItem="{Binding _Selectbrand}"/>
                            <Button Text="Enviar" 
                                    IsEnabled="{Binding IsNotBusy}"
                                    Command="{Binding _NewProductCommand}" 
                                    HorizontalOptions="Center" 
                                    WidthRequest="200"/>
                        </VerticalStackLayout>
                    </Border>


                    <Border Grid.Column="{OnPlatform Android=0,WinUI=1}" Grid.Row="{OnPlatform Android=1,WinUI=0}" Padding="10" Margin="10">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Informações Extras" FontAttributes="Bold" FontSize="24" HorizontalOptions="Center" />
                            <Label Text="Estoque Mínimo:" FontAttributes="Italic"/>
                            <Entry Placeholder="Estoque Mínimo" 
                                   Text="{Binding _product.Minimum_Stock}" 
                                   Keyboard="Numeric"/>
                            <Label Text="Valor de Uso:" FontAttributes="Italic"/>
                            <Entry Placeholder="Valor de Uso" 
                                   Text="{Binding _product.Usage_Value}" 
                                   Keyboard="Numeric"/>


                            <HorizontalStackLayout HorizontalOptions="Start">
                                <Button Text="Selecionar Fotos"  
                                        Command="{Binding _SelectImagesCommand}" 
                                        Margin="3">
                                    <Button.ImageSource>
                                        <FontImageSource Glyph="&#xf2c2;" 
                                                         FontFamily="FontAwesomeSolid" 
                                                         Size="24"/>
                                    </Button.ImageSource>
                                </Button>
                                <Label Text="{Binding count, StringFormat='Você Selecionou {0} Imagens'}" 
                                       VerticalOptions="Center" 
                                       TextColor="{AppThemeBinding Light=Black, Dark=White}"/>
                            </HorizontalStackLayout>
                            
                        </VerticalStackLayout>
                    </Border>
                </Grid>
            </StackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
