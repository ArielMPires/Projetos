<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Agnus.Views.SA001"
             xmlns:viewmodel="clr-namespace:Agnus.ViewModels"
             Title="">
    <ContentPage.BindingContext>
        <viewmodel:SA001ViewModel/>
    </ContentPage.BindingContext>

    <Grid Padding="10">
        <HorizontalStackLayout>
            <Button
            Command="{Binding _ReturnCommand}"
            TextColor="#0078D7"
            Padding="10"
            HorizontalOptions="StartAndExpand"
            VerticalOptions="Start"
            Margin="10">
                <Button.ImageSource>
                    <FontImageSource Glyph="&#xf060;" FontFamily="FontAwesomeSolid" Size="24"/>
                </Button.ImageSource>
            </Button>
            <Label Text="SA001"
               FontSize="20"
               Opacity="0.4"
               Rotation="0"
               TextColor="Gray"
              HorizontalOptions="EndAndExpand"
              VerticalOptions="Start"
              InputTransparent="True"/>
        </HorizontalStackLayout>
    </Grid>
</ContentPage>