<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:Agnus.ViewModels"
             x:Class="Agnus.Views.SK538"
             Title="">

    <Grid Padding="10">
        <HorizontalStackLayout VerticalOptions="End">
            <Label Text="SK538"
               FontSize="20"
               Opacity="0.3"
               Rotation="0"
               TextColor="Gray"
               HorizontalOptions="Start"
               VerticalOptions="End"
               InputTransparent="True"/>
        </HorizontalStackLayout>
        <HorizontalStackLayout HorizontalOptions="End" VerticalOptions="Start">
            <SearchBar Text="{Binding Search, Mode=TwoWay}"
                   Placeholder="Buscar Usuario..."
                       HeightRequest="10"
                       MaximumWidthRequest="1000"
                       HorizontalOptions="End"
                       />
        </HorizontalStackLayout>

        <Grid>
            <!-- Desktop View -->
            <CollectionView ItemsSource="{Binding Filter}" x:Name="DesktopList"
                     IsVisible="{OnPlatform Android=False, WinUI=True, MacCatalyst=True}">
                <CollectionView.Header>
                    <Border Padding="10" Style="{StaticResource HeaderBorder}">
                        <Grid ColumnDefinitions="*,*,*,*,*" RowDefinitions="Auto">

                            <BoxView Grid.Row="0" Grid.Column="0" WidthRequest="1" HorizontalOptions="End" BackgroundColor="#CCC"/>
                            <BoxView Grid.Row="0" Grid.Column="1" WidthRequest="1" HorizontalOptions="End" BackgroundColor="#CCC"/>
                            <BoxView Grid.Row="0" Grid.Column="2" WidthRequest="1" HorizontalOptions="End" BackgroundColor="#CCC"/>
                            <BoxView Grid.Row="0" Grid.Column="3" WidthRequest="1" HorizontalOptions="End" BackgroundColor="#CCC"/>


                            <Label Text="Cod." Grid.Column="0" FontSize="22" FontAttributes="Bold" HorizontalOptions="Center" Style="{StaticResource HeaderText}" />
                            <Label Text="Descrição" Grid.Column="1" FontSize="22" FontAttributes="Bold" HorizontalOptions="Center" Style="{StaticResource HeaderText}" />
                            <Label Text="Categoria" Grid.Column="2" FontSize="22" FontAttributes="Bold" HorizontalOptions="Center" Style="{StaticResource HeaderText}" />
                            <Label Text="Marca" Grid.Column="3" FontSize="22" FontAttributes="Bold" HorizontalOptions="Center" Style="{StaticResource HeaderText}" />
                            <Label Text="Quantidade" Grid.Column="4" FontSize="22" FontAttributes="Bold" HorizontalOptions="Center" Style="{StaticResource HeaderText}" />
                        </Grid>
                    </Border>
                </CollectionView.Header>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="10">
                            <StackLayout>
                                <!-- Linha principal -->
                                <Grid ColumnDefinitions="*,*,*,*,*" RowDefinitions="Auto" BackgroundColor="Transparent">

                                    <BoxView Grid.Row="0" Grid.Column="0" WidthRequest="1" HorizontalOptions="End" BackgroundColor="#CCC"/>
                                    <BoxView Grid.Row="0" Grid.Column="1" WidthRequest="1" HorizontalOptions="End" BackgroundColor="#CCC"/>
                                    <BoxView Grid.Row="0" Grid.Column="2" WidthRequest="1" HorizontalOptions="End" BackgroundColor="#CCC"/>
                                    <BoxView Grid.Row="0" Grid.Column="3" WidthRequest="1" HorizontalOptions="End" BackgroundColor="#CCC"/>


                                    <Label Text="{Binding value.ID}" Grid.Column="0" HorizontalOptions="Center" VerticalOptions="Center"/>
                                    <Label Text="{Binding value.Description}" Grid.Column="1" HorizontalOptions="Center" VerticalOptions="Center"/>
                                    <Label Text="{Binding value.Category}" Grid.Column="2" HorizontalOptions="Center" VerticalOptions="Center"/>
                                    <Label Text="{Binding value.Mark}" Grid.Column="3" HorizontalOptions="Center" VerticalOptions="Center"/>
                                    <HorizontalStackLayout Grid.Column="4" HorizontalOptions="Center" VerticalOptions="Center">
                                        <Label Text="{Binding value.Amount}" HorizontalOptions="Center" VerticalOptions="Center"/>
                                        <Label Text="{Binding value.Measure}" HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </HorizontalStackLayout>
                                </Grid>
                                <!-- Detalhes extras -->
                                <Grid Padding="10" BackgroundColor="Transparent"
                           IsVisible="{Binding IsChecked}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <HorizontalStackLayout Grid.Row="2" HorizontalOptions="Center">
                                        <Button
                                        Grid.Row="2"
                                        Padding="1"
                                        Margin="1"
                                        WidthRequest="50"
                                        Style="{StaticResource Circle}"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext._commandSK172}"
                                        CommandParameter="{Binding value.ID}">
                                            <Button.ImageSource>
                                                <FontImageSource Glyph="&#xf304;" Color="White" FontFamily="FontAwesomeSolid" Size="24"/>
                                            </Button.ImageSource>
                                        </Button>
                                        <Button
                                        Padding="1"
                                        Margin="2"
                                        MaximumWidthRequest="50"
                                            Style="{StaticResource Circle}"
                                        HorizontalOptions="StartAndExpand"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext._commandSK323}"
                                        CommandParameter="{Binding value.ID}">
                                            <Button.ImageSource>
                                                <FontImageSource Glyph="&#xf07c;" FontFamily="FontAwesomeSolid" Size="24"/>
                                            </Button.ImageSource>
                                        </Button>
                                    </HorizontalStackLayout>
                                </Grid>

                                <StackLayout.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding BindingContext.ToggleExpandCommand, Source={x:Reference DesktopList}}"
                           CommandParameter="{Binding .}"/>
                                </StackLayout.GestureRecognizers>
                            </StackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Mobile View -->
            <CollectionView ItemsSource="{Binding Filter}" x:Name="MobileList"
                     IsVisible="{OnPlatform Android=True, WinUI=False, MacCatalyst=False}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <StackLayout Padding="10" Spacing="5" BackgroundColor="Transparent">
                            <Border>
                                <Grid ColumnDefinitions="1*,2*" HeightRequest="30">
                                    <Label Text="{Binding value.ID}" Grid.Column="1" HorizontalOptions="Center" VerticalOptions="Center"/>
                                    <Label Text="{Binding value.Description}" Grid.Column="2" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Grid>
                            </Border>
                            <!-- Detalhes expansíveis -->
                            <StackLayout IsVisible="{Binding IsChecked}" BackgroundColor="Transparent" Padding="5">
                                <Label Text="{Binding value.Category, StringFormat='Categoria: {0}'}" Grid.Row="2" Grid.Column="1"/>
                                <Label Text="{Binding value.Mark, StringFormat='Marca: {0}'}" Grid.Row="2" Grid.Column="1"/>
                                    <HorizontalStackLayout Grid.Column="5" HorizontalOptions="Center" VerticalOptions="Center">
                                        <Label Text="{Binding value.Amount}" HorizontalOptions="Center" VerticalOptions="Center"/>
                                        <Label Text="{Binding value.Measure}" HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </HorizontalStackLayout>

                                <HorizontalStackLayout Grid.Row="2" HorizontalOptions="Center">
                                    <Button
                                        Grid.Row="2"
                                        Padding="1"
                                        Margin="1"
                                        WidthRequest="50"
                                        Style="{StaticResource Circle}"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext._commandSK172}"
                                        CommandParameter="{Binding value.ID}">
                                        <Button.ImageSource>
                                            <FontImageSource Glyph="&#xf304;" Color="White" FontFamily="FontAwesomeSolid" Size="24"/>
                                        </Button.ImageSource>
                                    </Button>
                                    <Button
                                        Padding="1"
                                        Margin="2"
                                        MaximumWidthRequest="50"
                                        HorizontalOptions="StartAndExpand"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext._commandSK323}"
                                        CommandParameter="{Binding value.ID}">
                                        <Button.ImageSource>
                                            <FontImageSource Glyph="&#xf07c;" FontFamily="FontAwesomeSolid" Size="24"/>
                                        </Button.ImageSource>
                                    </Button>
                                </HorizontalStackLayout>
                            </StackLayout>

                            <!-- Toque para expandir -->
                            <StackLayout.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding BindingContext.ToggleExpandCommand, Source={x:Reference MobileList}}"
                           CommandParameter="{Binding .}"/>
                            </StackLayout.GestureRecognizers>

                        </StackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </Grid>


        <Button 
            Padding="10"
            HorizontalOptions="End"
            VerticalOptions="End"
                Style="{StaticResource Circle}"
            Margin="10"
            x:Name="FabBtn"
            Command="{Binding _commandSK991}">
            <Button.ImageSource>
                <FontImageSource Glyph="&#x2b;" Color="White" FontFamily="FontAwesomeSolid" Size="24"/>
            </Button.ImageSource>
        </Button>
    </Grid>
</ContentPage>