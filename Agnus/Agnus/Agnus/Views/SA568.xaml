<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Agnus.Views.SA568"
             Title="">
    <Grid Padding="10">
        <Label Text="SA568"
               FontSize="20"
               Opacity="0.4"
               Rotation="0"
               TextColor="Gray"
       HorizontalOptions="Start"
VerticalOptions="End"
InputTransparent="True"/>

        <!-- Título -->
        <Label Margin="10" 
             Text="Nova Senha" 
             HorizontalOptions="Center" 
             FontSize="28" 
             FontAttributes="Bold"/>

        <ScrollView Margin="50">
            <Grid ColumnDefinitions="*" RowDefinitions="Auto">

                <Border Grid.Column="0" Padding="10" Margin="10">
                    <ScrollView>
                        <VerticalStackLayout Padding="10" Spacing="10">
                            <Label Text="Informações Basicas" 
                                 FontAttributes="Bold" 
                                 FontSize="24" 
                                 HorizontalOptions="Center"/>

                            <Label Text="Utilizador:" FontAttributes="Italic"/>
                            <Picker ItemsSource="{Binding User}" 
                                    ItemDisplayBinding="{Binding Name}" 
                                    SelectedItem="{Binding _SelectedUser}"/>

                            <Label Text="Tipo de Senha:" FontAttributes="Italic"/>
                            <Picker ItemsSource="{Binding Type}" 
                                    ItemDisplayBinding="{Binding Name}" 
                                    SelectedItem="{Binding _Selectedtype}"/>

                            <Label Text="Usuario:" FontAttributes="Italic"/>
                            <Entry Placeholder="Usuario" Text="{Binding _NewPassword.User}"/>

                            <Label Text="Senha:" FontAttributes="Italic"/>
                            <Entry Placeholder="Senha" IsPassword="True" Text="{Binding _NewPassword.Password}"/>

                            <Button Text="Enviar" 
                                  IsEnabled="{Binding IsNotBusy}"
                                  Command="{Binding _NewPasswordCommand}" 
                                  HorizontalOptions="Center" 
                                  WidthRequest="200"
                                  Margin="20,30,20,0"/>
                        </VerticalStackLayout>
                    </ScrollView>
                </Border>
            </Grid>
        </ScrollView>
    </Grid>
</ContentPage>