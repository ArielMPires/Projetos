<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:Agnus.ViewModels"
             x:Class="Agnus.Views.SG884"
             Title="">

    <Grid Padding="10">
        <HorizontalStackLayout>
            <Button
            IsVisible="{OnPlatform Android=true, iOS=true, WinUI=false}"
            Command="{Binding _ReturnCommand}"
            TextColor="#0078D7"
            Padding="10"
            HorizontalOptions="StartAndExpand"
            VerticalOptions="Start"
            Margin="10">
                <Button.ImageSource>
                    <FontImageSource Glyph="&#xf060;" FontFamily="FontAwesomeSolid" Size="24"/>
                </Button.ImageSource>
            </Button>
            <Label Text="SG884"
               FontSize="20"
               Opacity="0.4"
               Rotation="0"
               TextColor="Gray"
               HorizontalOptions="End"
               VerticalOptions="End"
               InputTransparent="True"/>
        </HorizontalStackLayout>
        <StackLayout Padding="20" VerticalOptions="Center" >
            <Border Padding="10" Margin="10">
                <VerticalStackLayout>
                    <Entry  Placeholder="Nome da categoria" Text="{Binding Type.Name}"/>
                    <BoxView Margin="10"/>
                    <Picker  Title="Categoria" ItemsSource="{Binding Category}" ItemDisplayBinding="{Binding Name}" SelectedIndex="{Binding _SelectedCatIndex, Mode=TwoWay}" SelectedItem="{Binding _SelectedCategory}"/>
                    <BoxView Margin="10"/>
                    <Picker  Title="Prioridade" ItemsSource="{Binding Priority}" ItemDisplayBinding="{Binding Name}" SelectedIndex="{Binding _SelectedPriorityIndex,Mode=TwoWay}" SelectedItem="{Binding _SelectedPriority}"/>
                    <BoxView Margin="10"/>
                    <Button Text="Enviar" Command="{Binding _EditTypeCommand}" IsEnabled="{Binding IsNotBusy}" HorizontalOptions="Center" WidthRequest="200"/>
                </VerticalStackLayout>
            </Border>
        </StackLayout>
    </Grid>
</ContentPage>