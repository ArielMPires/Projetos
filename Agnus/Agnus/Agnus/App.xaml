<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Agnus"
             xmlns:help="clr-namespace:Agnus.Helpers"
             x:Class="Agnus.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <help:TabColorConverter x:Key="TabColorConverter"/>
            <help:ButtonConverter x:Key="ButtonConverter"/>
            <help:BoolInverterConverter x:Key="BoolInverterConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
